# Environment variables for the Express API server

# Your TON wallet address (required)
PAYMENT_ADDRESS=

# TON network: testnet or mainnet
TON_NETWORK=testnet

# Jetton master address (optional, defaults to BSA USD)
# JETTON_MASTER_ADDRESS=kQCd6G7c_HUBkgwtmGzpdqvHIQoNkYOEE0kSWoc5v57hPPnW

# TON RPC endpoint
# TON_RPC_URL=https://testnet.toncenter.com/api/v2/jsonRPC

# Optional: RPC API key
# RPC_API_KEY=

# Facilitator URL (defaults to http://localhost:3001/api/facilitator)
# FACILITATOR_URL=

# Server port (defaults to 3001)
# PORT=3001
